# Security
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://yourdomain.com
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Logging
LOG_LEVEL=INFO
